class Solution {
  public:
    int reducingWalls(vector<int>& arr, int k) {
        int operations = 0;
        
        for(int i = 0; i < arr.size(); i++){
            if(arr[i] > k){
                operations += (arr[i] - 1) / k;
            }
        }
        
        return operations;
    }
};
