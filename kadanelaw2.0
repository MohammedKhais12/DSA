class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int maxArr = INT_MIN;
        int currSum = 0;

        for(int i=0; i<nums.size(); i++){
            currSum += nums[i];
            maxArr = max(maxArr, currSum);
            if(currSum<0){
                currSum = 0;
            }
        }
        return maxArr;
    }
};
