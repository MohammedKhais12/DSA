class Solution {
  public:
  
    void leaveSum(Node* root, int &sum){
        // Base case
        if(root == NULL){
            return;
        }
        
        // Check if leaf node
        if(root->left == NULL && root->right == NULL){
            sum += root->data;
            return;
        }
        
        // Recursive calls
        leaveSum(root->left, sum);
        leaveSum(root->right, sum);
    }
    
    int sumOfLeafNodes(Node *root) {
        int sum = 0;
        leaveSum(root, sum);
        return sum;
    }
};
