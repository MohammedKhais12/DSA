/* Link list Node
struct Node
{
    int data;
    struct Node* next;

    Node(int x){
        data = x;
        next = NULL;
    }

};
*/
class Solution {
  public:
    bool isCircular(Node *head) {
        // code here
        Node* temp = head->next;
        
        if(head==NULL || head->next==NULL){
            return false;
        }
        
        while(temp!=head){
            temp = temp->next;
            if(temp==NULL){
                return false;
            }
        }
        if(temp == head){
            return true;
        }
        return false;
    }
};
