class Solution {
  public:
    vector<int> Rearrange(vector<int> arr) {
        
        sort(arr.begin(), arr.end());
        vector<int> vec;
        int n = arr.size() - 1;

        for(int i = 0; i <= n/2; i++){
            if(i == n - i)
                vec.push_back(arr[i]);
            else{
                vec.push_back(arr[i]);
                vec.push_back(arr[n - i]);
            }
        }

        return vec;
    }
};
