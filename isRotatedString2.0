class Solution {
  public:
    bool isRotated(string& s1, string& s2) {
        // code here
        int n = s1.length();
        if(s1.length() != s2.length())
            return false;


        if(n < 2)
            return s1 == s2;
        string str1 = s1.substr(n-2) + s1.substr(0, n-2);
        string str2 = s1.substr(2) + s1.substr(0, 2);
        
        if(str1==s2 ||  str2==s2){
            return true;
        }
        return false;
    }
};
