class Solution {
  public:
    int firstOccurence(string& txt, string& pat) {
        // code here
        int count;
        for(int i=0; i<txt.size(); i++){
            count = 0;
            int j =0;
            int k = i;
            while(j<pat.length() && pat[j]==txt[i+j]){
                j++;
                count++;
            }
            if(count == pat.length()){
                return k;
            }
        }
        return -1;
    }
};
