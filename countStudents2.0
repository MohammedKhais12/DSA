class Solution {
public:
    int countStudents(vector<int>& students, vector<int>& sandwiches) {

        queue<int> q;
        stack<int> s;

        for(int st : students)
            q.push(st);

        for(int i = sandwiches.size() - 1; i >= 0; i--)
            s.push(sandwiches[i]);

        int rotations = 0;

        while(!q.empty() && rotations < q.size()) {

            if(q.front() == s.top()) {
                q.pop();
                s.pop();
                rotations = 0;   // reset rotation
            }
            else {
                q.push(q.front());
                q.pop();
                rotations++;
            }
        }

        return q.size();
    }
};
