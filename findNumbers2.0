class Solution {
public:
    int findNumbers(vector<int>& nums) {
        int finalCount = 0;
        int count;
        for(int i =0; i<nums.size(); i++){
            count = 0;
            int digit = nums[i];
            while(digit>0){
                digit /= 10;
                count++;
            }
            if(count%2==0){
                finalCount ++;
            }
        }
        return finalCount;
    }
};
