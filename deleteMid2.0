class Solution {
  public:
    Node* deleteMid(Node* head) {
        
        if(head == NULL || head->next == NULL){
            return NULL;  // single node case
        }
        
        int count = 0;
        Node* temp = head;
        
        // count nodes
        while(temp != NULL){
            count++;
            temp = temp->next;
        }
        
        int mid = count / 2;
        
        Node* curr = head;
        
        // go to node before middle
        for(int i = 0; i < mid - 1; i++){
            curr = curr->next;
        }
        
        // delete middle node
        curr->next = curr->next->next;
        
        return head;
    }
};
