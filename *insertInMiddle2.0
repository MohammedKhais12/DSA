struct Node {
  int data;
  struct Node *next;
  Node(int x) {
    data = x;
    next = NULL;
  }
};
*/

// Function to insert a node in the middle of the linked list.
class Solution {
  public:
    Node *insertInMiddle(Node *head, int x) {

        Node* newNode = new Node(x);

        if(head == NULL){
            return newNode;
        }

        Node* slow = head;
        Node* fast = head->next;   // 🔥 change here

        while(fast != NULL && fast->next != NULL){
            slow = slow->next;
            fast = fast->next->next;
        }

        newNode->next = slow->next;
        slow->next = newNode;

        return head;
    }
};
