class Solution { public: void roatate(vector<int>& nums, int st, int end){         while(st<end){             swap(nums[st], nums[end]);             st++;             end--;         }     }     void rotate(vector<int>& nums, int k) {         int n = nums.size();         k = k % n;                  roatate(nums, 0, n-1);         roatate(nums, 0, k-1);         roatate(nums, k, n-1);              } };
