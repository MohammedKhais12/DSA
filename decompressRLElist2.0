class Solution {
public:
    vector<int> decompressRLElist(vector<int>& nums) {
        vector <int> vec;
        for(int i = 0; i<nums.size(); i+=2){
            // int j = i;
            // int val = nums[i+1];
            int freq = nums[i];
            int val  = nums[i + 1];
            while(freq--) {
                vec.push_back(val);
            }
        }
        return vec;
    }
};
