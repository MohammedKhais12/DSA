#include <stack>
using namespace std;

class SpecialStack {
  public:
    stack<long long> st;
    long long min;

    SpecialStack() {
    }

    void push(int x) {

        if(st.empty()){
            st.push(x);
            min = x;
        }

        else if(x < min){
            st.push(2LL * x - min); 
            min = x;
        }

        else{
            st.push(x);
        }
    }

    void pop() {

        if(st.empty()) return;

        long long t = st.top();
        st.pop();

        if(t < min){
            min = 2*min - t;
        }
    }

    int peek() {

        long long t = st.top();

        if(t < min){
            return min;
        }

        return t;
    }

    bool isEmpty() {
        return st.empty();
    }

    int getMin() {
        return min;
    }
};
